// ===== STATE =====
let current = 0;
let answers = new Array(100).fill(null);
let scores = new Array(100).fill(null);

// ===== TOPIC RENDER =====
function renderTopics(){
  const c = document.getElementById('topics-list');
  c.innerHTML = topics.map((t,i)=>`
    <div>
      <div class="topic-head" onclick="toggleTopic(${i})">
        <h3 style="color:${t.color}">${t.title}</h3>
        <span id="arr-${i}" style="color:${t.color};font-size:18px">+</span>
      </div>
      <div class="topic-body" id="tb-${i}" style="display:none">
        <ul>${t.points.map(p=>`<li>${p}</li>`).join('')}</ul>
      </div>
      ${i<topics.length-1?'<hr class="thin">':''}
    </div>`).join('');
  // Open first
  toggleTopic(0);
}
function toggleTopic(i){
  const b=document.getElementById('tb-'+i);
  const a=document.getElementById('arr-'+i);
  const open=b.style.display==='block';
  b.style.display=open?'none':'block';
  a.textContent=open?'+':'−';
}

// ===== PIPELINE RENDER =====
const pipelineSteps=[
  "Data Ingestion","Embedding","Vector Store","Query Parsing","Agent Planner","Tool Calling","LLM Reasoning","Output Delivery"
];
function renderPipeline(){
  const c=document.getElementById('pipeline-viz');
  c.innerHTML=pipelineSteps.map((s,i)=>
    `<div class="pipe-step">${s}</div>${i<pipelineSteps.length-1?'<div class="pipe-arrow">→</div>':''}`
  ).join('');
  // Tools
  const tools=[
    {cat:"Agent Frameworks",items:["LangChain","LangGraph","AutoGen","CrewAI","AgentKit"]},
    {cat:"Vector DBs",items:["Pinecone","Weaviate","ChromaDB","Milvus","Qdrant"]},
    {cat:"LLM APIs",items:["OpenAI GPT-4o","Anthropic Claude","Google Gemini","Meta LLaMA","Mistral"]},
    {cat:"Cloud Platforms",items:["AWS Bedrock","Azure OpenAI","Google Vertex AI","Hugging Face","Together AI"]},
    {cat:"MLOps Tools",items:["MLflow","Weights & Biases","DVC","BentoML","Ray Serve"]},
    {cat:"Databases",items:["PostgreSQL","MongoDB","Redis","Elasticsearch","Neo4j"]}
  ];
  document.getElementById('tools-grid').innerHTML=tools.map(t=>`
    <div class="card" style="margin-bottom:.5rem">
      <h3>${t.cat}</h3>
      <div style="margin-top:6px">${t.items.map(i=>`<span class="tool-tag">${i}</span>`).join('')}</div>
    </div>`).join('');
  // Models
  const models=[
    {n:"GPT-4o",by:"OpenAI",type:"Multimodal"},
    {n:"Claude 3.5 Sonnet",by:"Anthropic",type:"Long context"},
    {n:"Gemini 1.5 Pro",by:"Google",type:"Multimodal"},
    {n:"LLaMA 3",by:"Meta",type:"Open weight"},
    {n:"Mistral Large",by:"Mistral AI",type:"Efficient"},
    {n:"Copilot",by:"Microsoft",type:"Enterprise"}
  ];
  document.getElementById('model-grid').innerHTML=`<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:8px">`+
  models.map(m=>`<div style="background:var(--color-background-secondary,#f5f5f5);border-radius:8px;padding:10px 12px">
    <div style="font-size:13px;font-weight:500">${m.n}</div>
    <div style="font-size:11px;color:var(--color-text-secondary)">${m.by}</div>
    <span class="tech-tag" style="margin-top:4px">${m.type}</span>
  </div>`).join('') + '</div>';
}

// ===== MCQ RENDER =====
function renderMCQ(){
  const q=mcqs[current];
  document.getElementById('q-counter').textContent=`Question ${current+1} / ${mcqs.length}`;
  document.getElementById('q-cat').textContent=q.cat;
  document.getElementById('q-text').textContent=q.q;
  document.getElementById('prog-bar').style.width=((current+1)/mcqs.length*100)+'%';
  const answered=answers.filter(a=>a!==null).length;
  const correct=scores.filter(s=>s===1).length;
  document.getElementById('score-val').textContent=Math.round(correct/Math.max(answered,1)*100)+'%';
  document.getElementById('correct-val').textContent=correct;
  document.getElementById('rem-val').textContent=mcqs.length-answered;
  const optsDiv=document.getElementById('q-opts');
  optsDiv.innerHTML='';
  q.opts.forEach((o,i)=>{
    const btn=document.createElement('button');
    btn.className='opt-btn';
    btn.textContent=`${String.fromCharCode(65+i)}. ${o}`;
    if(answers[current]!==null){
      btn.disabled=true;
      if(i===q.ans) btn.classList.add('correct');
      else if(i===answers[current]) btn.classList.add('wrong');
    }
    btn.onclick=()=>selectAnswer(i);
    optsDiv.appendChild(btn);
  });
  const expDiv=document.getElementById('q-exp');
  if(answers[current]!==null){
    expDiv.style.display='block';
    expDiv.innerHTML=`<div class="exp">💡 ${q.exp}</div>`;
  } else {
    expDiv.style.display='none';
  }
}
function selectAnswer(i){
  if(answers[current]!==null) return;
  answers[current]=i;
  scores[current]=i===mcqs[current].ans?1:0;
  renderMCQ();
}
function nextQ(){if(current<mcqs.length-1){current++;renderMCQ();}}
function prevQ(){if(current>0){current--;renderMCQ();}}
function skipQ(){nextQ();}
function resetQ(){
  if(!confirm('Reset all answers?')) return;
  answers=new Array(100).fill(null);
  scores=new Array(100).fill(null);
  current=0;
  renderMCQ();
}

// ===== TIPS RENDER =====
function renderTips(){
  const tips=[
    {icon:"⏰",t:"Log in to Superset by 7:15 PM — 15 min early to avoid last-minute tech issues"},
    {icon:"👥",t:"Individual scores aggregate to team score — everyone must participate actively"},
    {icon:"🧠",t:"Focus areas: GenAI fundamentals, Agentic AI concepts, SQL basics, IT knowledge"},
    {icon:"💡",t:"If unsure, eliminate 2 wrong answers first — often narrows to 50/50"},
    {icon:"⚡",t:"Don't overthink — go with your first instinct on factual questions"},
    {icon:"📱",t:"Coordinate with teammates on WeChat/WhatsApp — share answers for tricky questions"},
    {icon:"🔋",t:"Charge your device fully before the quiz — don't risk battery cutoff"},
    {icon:"🌐",t:"Ensure stable internet — use mobile hotspot as backup if WiFi is unreliable"}
  ];
  document.getElementById('tips-list').innerHTML=tips.map(t=>`
    <div style="display:flex;align-items:flex-start;gap:10px;padding:8px 0;border-bottom:0.5px solid var(--color-border-tertiary)">
      <span style="font-size:16px">${t.icon}</span>
      <span style="font-size:13px;color:var(--color-text-primary);line-height:1.6">${t.t}</span>
    </div>`).join('');
  const areas=[
    {area:"GenAI Basics",weight:"~30%",topics:"Transformers, prompting, RAG, hallucination, embeddings"},
    {area:"Agentic AI",weight:"~25%",topics:"ReAct, LangChain, multi-agent, tool calling, memory"},
    {area:"SQL / Data",weight:"~20%",topics:"Joins, window functions, CTEs, normalization, Text-to-SQL"},
    {area:"Cloud & IT",weight:"~15%",topics:"AWS/Azure/GCP, containers, CI/CD, microservices, APIs"},
    {area:"Capgemini Context",weight:"~10%",topics:"Company info, Buildathon rounds, program structure"}
  ];
  document.getElementById('test-areas').innerHTML=`<div style="margin-top:.5rem">`+areas.map(a=>`
    <div style="display:flex;justify-content:space-between;align-items:flex-start;padding:8px 0;border-bottom:0.5px solid var(--color-border-tertiary);gap:8px">
      <div>
        <div style="font-size:13px;font-weight:500">${a.area}</div>
        <div style="font-size:11px;color:var(--color-text-secondary)">${a.topics}</div>
      </div>
      <span style="font-size:12px;background:var(--c-primary-light);color:var(--c-primary);padding:3px 10px;border-radius:12px;white-space:nowrap;font-weight:500">${a.weight}</span>
    </div>`).join('')+'</div>';
}

// ===== NAV =====
function showTab(tab){
  ['notes','pipeline','mcq','tips'].forEach(t=>{
    document.getElementById('tab-'+t).style.display=t===tab?'block':'none';
  });
  document.querySelectorAll('.nav-btn').forEach((b,i)=>{
    b.classList.toggle('active',['notes','pipeline','mcq','tips'][i]===tab);
  });
}

// ===== INIT =====
renderTopics();
renderPipeline();
renderMCQ();
renderTips();
</script>
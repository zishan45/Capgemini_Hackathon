  {cat:"Agentic AI",q:"LangGraph extends LangChain for?",opts:["Graph database integration","Building stateful, multi-actor agentic workflows as graphs","Visualizing ML model graphs","Network topology mapping"],ans:1,exp:"LangGraph models agent workflows as directed graphs (nodes = agents/functions, edges = transitions), enabling complex stateful multi-agent flows."},

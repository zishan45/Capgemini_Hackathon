<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:var(--font-sans,sans-serif)}
:root{
  --c-primary:#534AB7;--c-primary-light:#EEEDFE;--c-teal:#0F6E56;--c-teal-light:#E1F5EE;
  --c-amber:#BA7517;--c-amber-light:#FAEEDA;--c-coral:#993C1D;--c-coral-light:#FAECE7;
  --c-green:#3B6D11;--c-green-light:#EAF3DE;
}
.sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}
#app{padding:0 0 2rem}
/* Header */
.hero{background:linear-gradient(135deg,var(--c-primary) 0%,#26215C 100%);color:#fff;padding:1.5rem 1.25rem;border-radius:var(--border-radius-lg,12px);margin-bottom:1rem}
.hero h1{font-size:20px;font-weight:500;margin-bottom:4px}
.hero p{font-size:13px;opacity:.8}
.badge-row{display:flex;flex-wrap:wrap;gap:8px;margin-top:12px}
.badge{background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.25);color:#fff;font-size:11px;padding:4px 10px;border-radius:20px}
/* Nav */
.nav{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:1rem}
.nav-btn{padding:7px 14px;font-size:13px;border:0.5px solid var(--color-border-secondary,#ccc);border-radius:20px;cursor:pointer;background:var(--color-background-primary,#fff);color:var(--color-text-secondary,#555);transition:all .2s;font-family:inherit}
.nav-btn.active,.nav-btn:hover{background:var(--c-primary);color:#fff;border-color:var(--c-primary)}
/* Cards */
.card{background:var(--color-background-primary,#fff);border:0.5px solid var(--color-border-tertiary,#e5e5e5);border-radius:var(--border-radius-lg,12px);padding:1rem 1.25rem;margin-bottom:.75rem}
.card h2{font-size:16px;font-weight:500;color:var(--color-text-primary,#111);margin-bottom:.5rem}
.card h3{font-size:14px;font-weight:500;margin-bottom:.4rem}
.card p{font-size:13px;color:var(--color-text-secondary,#555);line-height:1.7}
/* Section label */
.sec-label{font-size:11px;font-weight:500;letter-spacing:.05em;color:var(--color-text-tertiary,#888);text-transform:uppercase;margin-bottom:.5rem;padding-left:2px}
/* Pipeline viz */
.pipeline{display:flex;align-items:center;gap:0;overflow-x:auto;padding:8px 0;margin:8px 0}
.pipe-step{background:var(--c-primary-light);border:1px solid var(--c-primary);border-radius:8px;padding:8px 12px;font-size:12px;font-weight:500;color:var(--c-primary);white-space:nowrap;position:relative;min-width:90px;text-align:center}
.pipe-arrow{font-size:16px;color:var(--c-primary);padding:0 4px;flex-shrink:0}
/* Animated pill */
@keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.04)}}
.live-badge{display:inline-block;background:#e74c3c;color:#fff;font-size:11px;padding:3px 10px;border-radius:20px;animation:pulse 2s infinite;margin-left:8px}
/* MCQ */
.mcq-meta{display:flex;align-items:center;justify-content:space-between;margin-bottom:.75rem}
.mcq-counter{font-size:13px;color:var(--color-text-secondary,#555)}
.mcq-category{font-size:11px;background:var(--c-primary-light);color:var(--c-primary);padding:3px 10px;border-radius:12px;font-weight:500}
.mcq-q{font-size:14px;font-weight:500;color:var(--color-text-primary,#111);margin-bottom:.75rem;line-height:1.6}
.mcq-opts{display:flex;flex-direction:column;gap:7px;margin-bottom:.75rem}
.opt-btn{text-align:left;padding:9px 14px;font-size:13px;border:0.5px solid var(--color-border-secondary,#ddd);border-radius:8px;cursor:pointer;background:var(--color-background-secondary,#f9f9f9);color:var(--color-text-primary,#111);font-family:inherit;transition:all .15s;line-height:1.5}
.opt-btn:hover:not([disabled]){border-color:var(--c-primary);background:var(--c-primary-light)}
.opt-btn.correct{background:#EAF3DE;border-color:#3B6D11;color:#27500A}
.opt-btn.wrong{background:#FCEBEB;border-color:#A32D2D;color:#501313}
.opt-btn.reveal{background:var(--c-primary-light);border-color:var(--c-primary)}
.mcq-nav{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.mcq-nav button{padding:7px 14px;font-size:13px;border:0.5px solid var(--color-border-secondary,#ddd);border-radius:8px;cursor:pointer;background:var(--color-background-primary,#fff);font-family:inherit;color:var(--color-text-primary,#111);transition:all .15s}
.mcq-nav button:hover{border-color:var(--c-primary);color:var(--c-primary)}
.mcq-nav button.primary{background:var(--c-primary);color:#fff;border-color:var(--c-primary)}
.score-chip{font-size:12px;background:var(--c-green-light);color:var(--c-green);padding:4px 10px;border-radius:20px;font-weight:500}
.exp{font-size:12px;color:var(--color-text-secondary,#555);background:var(--color-background-secondary,#f5f5f5);border-radius:8px;padding:8px 12px;margin-top:4px;line-height:1.6;border-left:3px solid var(--c-primary)}
/* Progress bar */
.prog-wrap{height:6px;background:var(--color-border-tertiary,#eee);border-radius:3px;margin:8px 0 4px;overflow:hidden}
.prog-bar{height:100%;background:var(--c-primary);border-radius:3px;transition:width .4s}
/* Grid */
.grid2{display:grid;grid-template-columns:repeat(auto-fit,minmax(0,1fr));gap:.75rem}
.metric{background:var(--color-background-secondary,#f5f5f5);border-radius:var(--border-radius-md,8px);padding:.75rem 1rem}
.metric .val{font-size:22px;font-weight:500;color:var(--color-text-primary,#111)}
.metric .lbl{font-size:12px;color:var(--color-text-secondary,#666);margin-bottom:2px}
/* Tool tag */
.tool-tag{display:inline-block;background:var(--c-amber-light);color:var(--c-amber);font-size:11px;padding:3px 10px;border-radius:12px;margin:3px 3px 3px 0;font-weight:500}
.tech-tag{display:inline-block;background:var(--c-teal-light);color:var(--c-teal);font-size:11px;padding:3px 10px;border-radius:12px;margin:3px 3px 3px 0;font-weight:500}
/* Collapse */
.topic-head{cursor:pointer;display:flex;justify-content:space-between;align-items:center;padding:10px 0}
.topic-head h3{font-size:14px;font-weight:500}
.topic-body{font-size:13px;color:var(--color-text-secondary,#555);line-height:1.8;padding-bottom:8px}
.topic-body ul{padding-left:16px}
.topic-body li{margin-bottom:4px}
hr.thin{border:none;border-top:0.5px solid var(--color-border-tertiary,#eee);margin:2px 0}
/* Anim flow */
@keyframes flowRight{0%{left:-100%}100%{left:110%}}
.flow-track{position:relative;height:4px;background:#e5e5e5;border-radius:2px;overflow:hidden;margin:6px 0}
.flow-dot{position:absolute;top:0;left:-60%;width:40%;height:100%;background:linear-gradient(90deg,transparent,var(--c-primary),transparent);border-radius:2px;animation:flowRight 1.8s ease-in-out infinite}
</style>

<h2 class="sr-only">Capgemini Exceller AgentifAI Buildathon 2026 – Complete Study Guide with 100 MCQs</h2>


<script>
// ===== TOPICS DATA =====
const topics = [
  {
    title:"🤖 Generative AI — Foundations",
    color:"var(--c-primary)",
    bg:"var(--c-primary-light)",
    points:[
      "Generative AI creates new content (text, images, code, audio) by learning patterns from training data",
      "Foundation Models: Large pre-trained models fine-tuned for downstream tasks (GPT-4, Gemini, Claude, LLaMA)",
      "Transformer Architecture: Attention mechanism, encoder-decoder, self-attention heads",
      "Tokens: Basic units of text; tokenization converts text to numerical IDs",
      "Embeddings: Dense vector representations capturing semantic meaning",
      "Training: Pre-training on large corpus → Fine-tuning on task-specific data → RLHF (Reinforcement Learning from Human Feedback)",
      "Prompt Engineering: Zero-shot, few-shot, chain-of-thought (CoT), retrieval-augmented generation (RAG)",
      "Hallucination: When LLMs generate factually incorrect but confident outputs",
      "Temperature &amp; Top-P: Control randomness/creativity in output generation",
      "Context Window: Maximum tokens an LLM can process in one inference (4K–200K+)"
    ]
  },
  {
    title:"🧠 Agentic AI — Core Concepts",
    color:"var(--c-teal)",
    bg:"var(--c-teal-light)",
    points:[
      "Agentic AI: AI systems that autonomously plan, reason, act, and execute multi-step tasks without constant human supervision",
      "ReAct Framework: Reason → Act → Observe cycle; agent thinks then takes action",
      "Autonomous Agents: Can call tools, browse the web, write/run code, and self-correct",
      "Multi-Agent Systems: Multiple specialized agents collaborate (Orchestrator + Sub-agents)",
      "Tool Calling / Function Calling: LLMs invoking external APIs, databases, or code",
      "Memory Types: In-context (short-term), external vector DB (long-term), episodic memory",
      "Planning: Task decomposition (Tree of Thought, Plan-and-Solve), goal hierarchies",
      "Reflection &amp; Self-critique: Agent evaluates its own output and revises",
      "Agent Frameworks: LangChain, LangGraph, AutoGen, CrewAI, AgentKit (Capgemini stack)",
      "Human-in-the-Loop (HITL): Checkpoints where humans approve/override agent actions"
    ]
  },
  {
    title:"🗄️ SQL &amp; Data Engineering",
    color:"var(--c-amber)",
    bg:"var(--c-amber-light)",
    points:[
      "SQL Phantom Round: Tests SQL queries, optimization, and data agent integration",
      "DDL: CREATE, ALTER, DROP, TRUNCATE — defines schema structure",
      "DML: SELECT, INSERT, UPDATE, DELETE — manipulates data",
      "Joins: INNER, LEFT, RIGHT, FULL OUTER, CROSS, SELF joins",
      "Subqueries: Scalar, correlated, and derived table subqueries",
      "Window Functions: ROW_NUMBER(), RANK(), DENSE_RANK(), LAG(), LEAD(), NTILE()",
      "CTEs (Common Table Expressions): WITH clause for readable recursive queries",
      "Indexes: B-tree, hash, composite; speed up reads, slow down writes",
      "Normalization: 1NF → 2NF → 3NF → BCNF; reduce redundancy",
      "Text-to-SQL: Agentic AI converting natural language to SQL via LLM",
      "Vector Databases: Pinecone, Weaviate, ChromaDB — store embeddings for semantic search",
      "RAG Pipeline: Retrieve relevant chunks from DB → augment LLM prompt → generate answer"
    ]
  },
  {
    title:"☁️ Cloud &amp; IT Infrastructure",
    color:"var(--c-coral)",
    bg:"var(--c-coral-light)",
    points:[
      "Cloud Providers: AWS (market leader), Azure (Microsoft), GCP (Google) — all support GenAI services",
      "IaaS / PaaS / SaaS: Infrastructure / Platform / Software as a Service delivery models",
      "Microservices: Independently deployable services communicating via APIs (REST, gRPC)",
      "Containers &amp; Kubernetes: Docker containers orchestrated by K8s for scalable AI deployment",
      "CI/CD: Continuous Integration / Continuous Deployment — automated build, test, deploy pipelines",
      "Serverless: Functions-as-a-Service (AWS Lambda, Azure Functions) for event-driven AI agents",
      "API Gateway: Manages, secures, and routes API calls between services and agents",
      "DevOps + MLOps: MLOps extends DevOps principles to ML model lifecycle management",
      "Observability: Logging, tracing, metrics (Prometheus, Grafana, OpenTelemetry)",
      "Security: OAuth 2.0, JWT tokens, RBAC, prompt injection protection in agentic systems"
    ]
  },
  {
    title:"🏭 Capgemini &amp; Industry Context",
    color:"var(--c-green)",
    bg:"var(--c-green-light)",
    points:[
      "Capgemini: Global IT services leader; 420,000+ employees across 50+ countries",
      "Vision 2026: 'AI for All – Human, Inclusive, and Sustainable' — Year of Innovation",
      "Buildathon Rounds: Campus Showdown → SQL Phantom + Agent Builder → Elevator Pitch → Deep Dive Technical → Finale (May 31)",
      "Superset Platform: Official platform for team registration and round submissions",
      "Team Structure: 1 Captain + 5 members from same university; individual scores aggregate to team score",
      "Capgemini AI portfolio: Applied Innovation Exchange (AIE), Gen AI practice, AI-powered BPO",
      "Digital Transformation pillars: Cloud-first, AI-augmented, data-driven, sustainable IT",
      "Key sectors served: BFSI, Healthcare, Retail, Manufacturing, Energy, Public Sector",
      "Capgemini Exceller: Flagship campus hiring program targeting 2026/2027 graduates",
      "Partnership model: Capgemini uses Azure OpenAI, AWS Bedrock, Google Vertex AI at enterprise scale"
    ]
  }
];

// ===== MCQ DATA (100 questions) =====
const mcqs = [
  // GenAI Basics (1-20)
  {cat:"GenAI Basics",q:"What is the primary architecture underlying most modern Large Language Models (LLMs)?",opts:["Recurrent Neural Network (RNN)","Convolutional Neural Network (CNN)","Transformer with self-attention","Generative Adversarial Network (GAN)"],ans:2,exp:"Transformers with self-attention mechanisms replaced RNNs as the dominant architecture for LLMs since the 'Attention Is All You Need' paper (2017)."},
  {cat:"GenAI Basics",q:"What does 'hallucination' mean in the context of LLMs?",opts:["The model crashes due to overload","The model generates factually incorrect but confident text","The model refuses to answer","The model generates very slow responses"],ans:1,exp:"Hallucination refers to LLMs producing plausible-sounding but factually wrong or fabricated information."},
  {cat:"GenAI Basics",q:"What is 'few-shot prompting'?",opts:["Training the model on a few examples","Providing 2-5 examples in the prompt before the actual query","Running the model on minimal hardware","Reducing model parameters"],ans:1,exp:"Few-shot prompting gives the LLM 2-5 examples within the prompt so it can infer the pattern and apply it to the actual task."},
  {cat:"GenAI Basics",q:"What does RAG stand for in AI?",opts:["Rapid AI Generation","Retrieval-Augmented Generation","Random Agent Grounding","Recursive Attention Generation"],ans:1,exp:"RAG (Retrieval-Augmented Generation) retrieves relevant context from a knowledge base and injects it into the LLM prompt to improve accuracy."},
  {cat:"GenAI Basics",q:"What is the 'context window' of an LLM?",opts:["The GUI window of the AI app","Maximum tokens the model can process in one inference","The training data size","The number of parameters in the model"],ans:1,exp:"The context window defines how many tokens (input + output) an LLM can handle in a single call — ranging from 4K to 200K+ tokens in modern models."},
  {cat:"GenAI Basics",q:"Which parameter controls randomness/creativity in LLM output?",opts:["Learning rate","Batch size","Temperature","Dropout rate"],ans:2,exp:"Temperature (0–2) controls output randomness. Low values = deterministic, high values = creative/random."},
  {cat:"GenAI Basics",q:"What is 'Chain-of-Thought' (CoT) prompting?",opts:["Connecting multiple LLMs in series","Asking the model to show step-by-step reasoning before answering","Chaining database queries","Using blockchain for AI verification"],ans:1,exp:"CoT prompting instructs the LLM to reason through a problem step-by-step, significantly improving performance on complex tasks."},
  {cat:"GenAI Basics",q:"What are 'embeddings' in NLP?",opts:["Compressed image files","Dense vector representations capturing semantic meaning of text","Database foreign keys","CSS styling properties"],ans:1,exp:"Embeddings are numerical vector representations of text where semantically similar words/sentences are close in vector space."},
  {cat:"GenAI Basics",q:"RLHF stands for?",opts:["Reinforcement Learning for Human Feedback","Reinforced LLM Hallucination Fix","Reinforcement Learning from Human Feedback","Recursive Learning with Human Filters"],ans:2,exp:"RLHF aligns LLMs with human preferences by training a reward model on human ratings and using RL to optimize the LLM towards it."},
  {cat:"GenAI Basics",q:"Which of these is a foundation model developed by Meta?",opts:["GPT-4","Gemini","LLaMA","Claude"],ans:2,exp:"LLaMA (Large Language Model Meta AI) is Meta's open-weight foundation model family, widely used for fine-tuning."},
  {cat:"GenAI Basics",q:"What is 'fine-tuning' in the context of LLMs?",opts:["Adjusting the app's font size","Further training a pre-trained model on task-specific data","Cleaning training data","Deploying the model to production"],ans:1,exp:"Fine-tuning adapts a pre-trained foundation model to a specific domain or task using a smaller, targeted dataset."},
  {cat:"GenAI Basics",q:"What does 'top-p' (nucleus sampling) control in LLM generation?",opts:["The number of output paragraphs","The probability mass from which tokens are sampled","The maximum response length","The model's memory usage"],ans:1,exp:"Top-p sampling picks from the smallest set of tokens whose cumulative probability exceeds p, balancing diversity and quality."},
  {cat:"GenAI Basics",q:"Which company developed the GPT series of models?",opts:["Google","Anthropic","OpenAI","Microsoft"],ans:2,exp:"OpenAI developed the GPT (Generative Pre-trained Transformer) series, including GPT-3, GPT-4, etc."},
  {cat:"GenAI Basics",q:"What is a 'prompt' in the context of LLMs?",opts:["A system alert message","The input text given to an LLM to generate a response","A model parameter","A database query"],ans:1,exp:"A prompt is the input text or instruction provided to an LLM, which guides what the model generates."},
  {cat:"GenAI Basics",q:"What is 'zero-shot prompting'?",opts:["Asking the model with no examples or demonstrations","Training from scratch","Using zero GPU memory","Disabling the model's memory"],ans:0,exp:"Zero-shot prompting asks the LLM to perform a task without providing any examples, relying solely on its pre-trained knowledge."},
  {cat:"GenAI Basics",q:"Which metric measures how similar two text embeddings are?",opts:["Euclidean distance only","Cosine similarity","Hamming distance","Levenshtein distance"],ans:1,exp:"Cosine similarity measures the angle between embedding vectors — commonly used in semantic search and RAG retrieval."},
  {cat:"GenAI Basics",q:"What is 'model quantization'?",opts:["Measuring model accuracy","Reducing model size by using lower-precision numbers","Training on quantum computers","Counting model parameters"],ans:1,exp:"Quantization reduces model precision (e.g., FP32→INT8) to decrease size and increase inference speed with minimal accuracy loss."},
  {cat:"GenAI Basics",q:"Anthropic's AI assistant is called?",opts:["GPT","Gemini","Claude","Copilot"],ans:2,exp:"Anthropic developed Claude, their AI assistant known for safety-focused design and long context windows."},
  {cat:"GenAI Basics",q:"What is the 'system prompt' in an LLM API call?",opts:["The server startup command","Instructions that define the AI's persona/behavior before user messages","The model's training script","A SQL query for data retrieval"],ans:1,exp:"The system prompt sets the AI's role, persona, constraints, and behavior — it's invisible to end users but shapes all responses."},
  {cat:"GenAI Basics",q:"What does 'multimodal AI' refer to?",opts:["AI running on multiple servers","AI that processes multiple data types (text, images, audio, video)","AI with multiple personalities","Multi-threaded AI processing"],ans:1,exp:"Multimodal AI models like GPT-4o and Gemini can process and generate content across text, images, audio, and video."},
  // Agentic AI (21-40)
  {cat:"Agentic AI",q:"What is an 'AI Agent'?",opts:["A human who tests AI systems","An AI system that autonomously plans and executes multi-step tasks","A simple chatbot with a fixed script","An AI model without any training"],ans:1,exp:"AI Agents autonomously perceive their environment, reason about goals, take actions (tool calls), and adapt based on feedback."},
  {cat:"Agentic AI",q:"What does the ReAct framework stand for?",opts:["Reason and Code","Reactive AI Components","Reasoning + Acting","Reliable AI Chains of Thought"],ans:2,exp:"ReAct (Reasoning + Acting) interleaves thought steps and action steps, allowing agents to reason about what action to take next."},
  {cat:"Agentic AI",q:"What is 'tool calling' or 'function calling' in agentic AI?",opts:["Installing software tools","LLMs invoking external APIs, databases, or code executors","Calling a human support agent","A debugging technique"],ans:1,exp:"Tool/function calling allows LLMs to invoke pre-defined functions (APIs, DB queries, calculators) and receive their output."},
  {cat:"Agentic AI",q:"Which framework is widely used to build agentic LLM applications?",opts:["TensorFlow","LangChain","Hadoop","Apache Spark"],ans:1,exp:"LangChain is the most popular framework for building agentic LLM apps, providing chains, agents, memory, and tool integrations."},
  {cat:"Agentic AI",q:"What is a 'Multi-Agent System'?",opts:["A single AI agent with multiple identities","Multiple specialized AI agents collaborating to complete complex tasks","An AI running on multiple GPUs","A human team using AI tools"],ans:1,exp:"Multi-Agent Systems deploy multiple specialized agents (e.g., researcher + coder + critic) that collaborate and share results."},
  {cat:"Agentic AI",q:"What is 'Human-in-the-Loop' (HITL) in agentic AI?",opts:["A human manually writing all AI outputs","Checkpoints where humans review/approve agent actions before proceeding","Humans monitoring AI 24/7","Replacing AI with humans"],ans:1,exp:"HITL maintains human oversight at key decision points, allowing approval or redirection of agent actions for safety and accuracy."},
  {cat:"Agentic AI",q:"CrewAI is used for?",opts:["Customer relationship management","Orchestrating role-based multi-agent workflows","Cloud resource monitoring","Cybersecurity incident response"],ans:1,exp:"CrewAI is a framework for creating role-based multi-agent 'crews' where each agent has a specific role, goal, and backstory."},
  {cat:"Agentic AI",q:"What type of memory allows an agent to remember past conversations long-term?",opts:["In-context (prompt) memory","RAM memory","External vector database memory","Session cookies"],ans:2,exp:"External vector databases (Pinecone, ChromaDB) store embeddings of past interactions, enabling long-term persistent memory for agents."},
  {cat:"Agentic AI",q:"What is 'prompt injection' in agentic AI?",opts:["Adding extra prompts to improve output","Malicious instructions hidden in external content that hijack agent behavior","Injecting training data","A debugging technique"],ans:1,exp:"Prompt injection is an attack where malicious text in agent inputs (e.g., web pages) overrides the original instructions."},
  {cat:"Agentic AI",q:"The 'Orchestrator' agent in a multi-agent system is responsible for?",opts:["Storing embeddings","Coordinating and delegating tasks to sub-agents","Writing code","Handling user authentication"],ans:1,exp:"The orchestrator agent manages the overall workflow, breaks down goals, and delegates subtasks to specialized sub-agents."},
  {cat:"Agentic AI",q:"What is 'Tree of Thought' (ToT) prompting?",opts:["A hierarchical data structure for storing prompts","Exploring multiple reasoning paths simultaneously before selecting the best","A decision tree ML model","A visualization tool for LLM outputs"],ans:1,exp:"Tree of Thought lets the LLM explore multiple solution branches simultaneously, using search algorithms to find the optimal path."},
